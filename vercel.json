{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/**/*.py": {
      "runtime": "@vercel/python@4.5.0",
      "includeFiles": [
        "backend/main.py",
        "backend/database/**",
        "backend/middleware/**",
        "backend/routers/**",
        "backend/schemas/**",
        "backend/services/**"
      ]
    }
  },
  "rewrites": [
    { "source": "/api/v1/(.*)", "destination": "/api/index.py" },
    { "source": "/((?!api|assets|vite\\.svg|.*\\..*).*)", "destination": "/index.html" }
  ]
}
