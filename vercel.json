{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_backend"
    }
  },
  "rewrites": [
    {
      "source": "/((?!_backend|api|assets|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
