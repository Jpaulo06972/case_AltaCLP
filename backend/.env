# ============================================
# AltaCLP Intelligence Platform — Configuração
# ============================================

# Banco de dados PostgreSQL (Configurado via Docker Compose)
DATABASE_URL=postgresql://altaclp:altaclp123@localhost:5432/altaclp_db

# Chave secreta JWT (mínimo 32 caracteres)
SECRET_KEY=altaclp-secret-key-dev-mode-2026-homodeus-platform-supersecret

# Anthropic API Key para módulos de IA (Substitua por sua chave sk-ant-...)
ANTHROPIC_API_KEY=sk-ant-...

# Ambiente: development | staging | production
ENVIRONMENT=development

# CORS — origens permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500,http://localhost:8080
