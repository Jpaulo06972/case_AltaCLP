# URL da API (obrigatório no Vercel se o backend NÃO estiver no mesmo projeto)
# Deixe vazio em monorepo Vercel: o build usa /_backend/api/v1 automaticamente
# VITE_API_URL=https://seu-app.vercel.app/_backend/api/v1

# Desenvolvimento local (opcional — já é o padrão)
# VITE_API_URL=http://localhost:8000/api/v1
